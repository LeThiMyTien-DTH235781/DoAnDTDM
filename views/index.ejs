                    <option value="Công việc">💼 Công việc</option>
                    <option value="Cá nhân">🌸 Cá nhân</option>
                    <option value="Ý tưởng">💡 Ý tưởng</option>
                </select>
            </div>
            <textarea name="content" placeholder="Nội dung ghi chú..." rows="3" required></textarea>
            <div style="text-align: right; margin-top: 10px;">
                <button type="submit" class="btn-add">✨ Thêm ghi chú</button>
            </div>
        </form>
    </div>

    <div class="grid">
        <% if (notes.length === 0) { %>
            <div style="grid-column: 1/-1; text-align: center; color: #94a3b8; padding: 40px;">
                <p>Hổng có ghi chú nào hết!</p>
            </div>
        <% } %>

        <% notes.forEach(note => { %>
            <div class="card <%= note.pinned ? 'pinned-card' : '' %>">
                <span class="tag <%= note.category === 'Công việc' ? 'tag-work' : (note.category === 'Ý tưởng' ? 'tag-idea' : 'tag-personal') %>">
                    <%= note.category %>
                </span>
                <div class="card-title"><%= note.title %></div>
                <div class="card-content"><%= note.content %></div>
                <div class="card-footer">
                    <a href="/pin/<%= note._id %>" class="icon-btn <%= note.pinned ? 'pin-active' : '' %>" title="Ghim">
                        <i data-lucide="pin" size="14"></i>
                    </a>
					<a href="/edit/<%= note._id %>" class="icon-btn" title="Chỉnh sửa" style="color: #3b82f6;">
        <i data-lucide="pencil" size="14"></i>
    </a>
                    <a href="/delete/<%= note._id %>" class="icon-btn" onclick="return confirm('Bạn chắc chắn muốn xóa?')" title="Xóa">
                        <i data-lucide="trash-2" size="14"></i>
                    </a>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<div id="toast" class="toast"></div>

<script>
    lucide.createIcons();

    // Hàm hiện thông báo
   function showToast(msg) {
        const toast = document.getElementById('toast');
        toast.innerText = msg;
        toast.style.display = "block";
        setTimeout(() => toast.style.display = "none", 2500);
    }

   const urlParams = new URLSearchParams(window.location.search);
		if (urlParams.get('pinned')) {
			showToast("📌 Đã cập nhật trạng thái ghim!");
		} else if (urlParams.get('added')) {
			showToast("✅ Đã thêm thành công!");
		} else if (urlParams.get('deleted')) {
			showToast("🗑️ Đã xóa ghi chú!");
		} else if (urlParams.get('edited')) {
			showToast("✏️ Đã lưu thay đổi!");
		}	
    // Giữ focus vào ô tìm kiếm nếu đang search
    if(urlParams.get('search')) {
        const input = document.querySelector('input[name="search"]');
        input.focus();
        // Đưa con trỏ xuống cuối chữ
        const val = input.value;
        input.value = '';
        input.value = val;
    }
</script>
