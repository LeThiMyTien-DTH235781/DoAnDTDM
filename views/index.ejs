        <div class="stat-card"><div class="stat-num" style="color:#ec4899"><%= counts['Cá nhân'] %></div><div class="stat-label">Cá nhân</div></div>
        <div class="stat-card"><div class="stat-num" style="color:#f59e0b"><%= counts['Ý tưởng'] %></div><div class="stat-label">Ý tưởng</div></div>
    </div>

    <div class="form-box">
        <form action="/add" method="POST">
            <div class="form-row">
                <input type="text" name="title" placeholder="Tiêu đề..." required>
