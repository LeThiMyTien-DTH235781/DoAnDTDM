                </form>
            </div>

            <div class="stats-bar">
                <a href="/" style="text-decoration: none;">
                    <div class="stat-card">
                        <h3>
                            <%= stats.total %>
                        </h3>
                        <p>Tổng số</p>
                    </div>
                </a>

                <a href="/category/work" style="text-decoration: none;">
                    <div class="stat-card">
                        <h3 style="color: var(--primary);">
                            <%= stats.work %>
                        </h3>
                        <p>Công việc</p>
                    </div>
                </a>

                <a href="/category/personal" style="text-decoration: none;">
                    <div class="stat-card">
                        <h3 style="color: var(--pink);">
                            <%= stats.personal %>
                        </h3>
                        <p>Cá nhân</p>
                    </div>
                </a>

                <a href="/category/idea" style="text-decoration: none;">
                    <div class="stat-card">
                        <h3 style="color: var(--yellow);">
                            <%= stats.idea %>
                        </h3>
                        <p>Ý tưởng</p>
                    </div>
                </a>
            </div>

            <div class="input-section">
                <form action="/add-note" method="POST">
                    <input name="title" placeholder="Tiêu đề..." required>
                    <textarea name="content" rows="3" placeholder="Bạn đang nghĩ gì..." required></textarea>
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <select name="category" style="width: auto; margin-bottom: 0;">
                            <option value="Công việc">Công việc</option>
                            <option value="Cá nhân">Cá nhân</option>
                            <option value="Ý tưởng">Ý tưởng</option>
                        </select>
                        <button type="submit" class="btn-add">✨ Thêm ngay</button>
                    </div>
                </form>
            </div>

            <div class="note-grid">
                <% notes.forEach(note=> {
                    let typeClass = (note.category === 'Cá nhân') ? 'personal' : (note.category === 'Ý tưởng' ? 'idea' :
                    'work');
                    %>
                    <div class="note-card note-<%= typeClass %>">
                        <a href="/pin/<%= note._id %>" class="pin-btn <%= note.isPinned ? '' : 'not-pinned' %>">
                            <%= note.isPinned ? '📌' : '📍' %>
                        </a>
                        <span
                            style="font-size: 11px; padding: 6px 14px; border-radius: 100px; font-weight: 700; background: #f1f5f9;">
                            <%= note.category %>
                        </span>
                        <h3 style="margin: 15px 0 10px;">
                            <%= note.title %>
                        </h3>
                        <p style="color: #475569; font-size: 14px; line-height: 1.5;">
                            <%= note.content %>
                        </p>
                        <div style="margin-top: 20px; border-top: 1px solid #f1f5f9; padding-top: 15px;">
                            <button class="btn-add"
                                style="padding: 8px 15px; background: none; color: #64748b; border: 1px solid #e2e8f0;"
                                onclick="openEditModal('<%= note._id %>', '<%= note.title %>', '<%= note.content %>', '<%= note.category %>')">✏️
                                Sửa</button>
                            <a href="/delete/<%= note._id %>" onclick="return confirm('Xóa nhé?')"
                                style="margin-left: 10px; color: #ef4444; text-decoration: none; font-size: 14px;">🗑️
                                Xóa</a>
                        </div>
                    </div>
                    <% }) %>
            </div>
        </div>

        <div class="modal-overlay" id="editModal">
            <div class="modal-card">
                <h2>✏️ Chỉnh sửa ghi chú</h2>
                <form id="editForm" method="POST">
                    <input type="text" name="title" id="editTitle" placeholder="Tiêu đề mới..." required>
                    <textarea name="content" id="editContent" rows="5" placeholder="Nội dung mới..."
                        required></textarea>

                    <label style="font-size: 13px; color: #94a3b8; margin-left: 5px;">Danh mục:</label>
                    <select name="category" id="editCategory">
                        <option value="Công việc">💼 Công việc</option>
                        <option value="Cá nhân">🌸 Cá nhân</option>
                        <option value="Ý tưởng">💡 Ý tưởng</option>
                    </select>

                    <div class="modal-footer">
                        <button type="button" class="btn-cancel" onclick="closeModal()">Hủy</button>
                        <button type="submit" class="btn-save">Cập nhật ngay</button>
                    </div>
                </form>
            </div>
        </div>

        <script>
            // Xử lý Search và Nút X
            const searchInput = document.getElementById('searchInput');
            const clearSearch = document.getElementById('clearSearch');

            function toggleClearBtn() {
                clearSearch.style.display = searchInput.value.trim() !== "" ? "block" : "none";
            }

            searchInput.addEventListener('input', toggleClearBtn);
            window.addEventListener('DOMContentLoaded', toggleClearBtn);

            clearSearch.addEventListener('click', () => {
                searchInput.value = '';
                window.location.href = '/';
            });

            // Xử lý Modal
            function openEditModal(id, title, content, category) {
                document.getElementById('editForm').action = '/edit/' + id;
                document.getElementById('editTitle').value = title;
                document.getElementById('editContent').value = content;
                document.getElementById('editCategory').value = category;
                document.getElementById('editModal').style.display = 'flex';
            }

            function closeModal() { document.getElementById('editModal').style.display = 'none'; }
        </script>
</body>

