<style>
    .sidebar {
        width: 260px; background: white; height: 100vh; position: fixed;
        left: 0; top: 0; padding: 30px 20px; box-sizing: border-box;
        border-right: 1px solid #f1f5f9; display: flex; flex-direction: column;
        overflow-y: auto;
    }
    .nav-group-bottom { margin-top: auto; padding-bottom: 20px; }
    .brand { font-size: 22px; font-weight: 800; color: #6366f1; margin-bottom: 40px; display: flex; align-items: center; gap: 10px; }
    .nav-label { font-size: 11px; text-transform: uppercase; color: #94a3b8; letter-spacing: 1px; margin-bottom: 15px; display: block; padding-left: 10px; }
    .nav-item { display: flex; align-items: center; padding: 10px 15px; margin-bottom: 2px; text-decoration: none; color: #475569; font-weight: 500; border-radius: 12px; transition: 0.2s; }
    .nav-item:hover { background: #f1f5f9; color: #6366f1; transform: translateX(5px); }
    .nav-item.active { background: #eef2ff; color: #6366f1; }
    .logout { color: #f43f5e !important; }
</style>

